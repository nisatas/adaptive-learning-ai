# Copy to backend/.env — Puq.ai keys are backend-only

PUQ_AI_API_KEY=
PUQ_AI_BASE_URL=https://api.puq.ai
PUQ_AI_MODEL=openai/gpt-4o-mini
PUQ_AI_CHAT_ENDPOINT=/v1/chat/completions

PUQ_MEET_WORKFLOW_URL=
PUQ_SUPPORT_PLAN_WORKFLOW_URL=
PUQ_WEEKLY_REPORT_WORKFLOW_URL=

DEMO_MODE=false
PORT=4000
NODE_ENV=development

# Local dev only if Puq.ai SSL fails on Windows (see backend logs SSL_ERROR):
# NODE_TLS_REJECT_UNAUTHORIZED=0
