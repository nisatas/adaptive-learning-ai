# Puq.ai — call only from backend (never commit real keys)
PUQ_AI_API_KEY=
PUQ_AI_BASE_URL=https://api.puq.ai
PUQ_AI_MODEL=openai/gpt-4o-mini
PUQ_AI_CHAT_ENDPOINT=/v1/chat/completions

# Puq.ai workflow webhooks (backend only)
PUQ_MEET_WORKFLOW_URL=
PUQ_SUPPORT_PLAN_WORKFLOW_URL=
PUQ_WEEKLY_REPORT_WORKFLOW_URL=

# Optional aliases (also supported): PUQAI_API_KEY, PUQAI_BASE_URL, etc.

# Set true to skip live Puq.ai calls and use rule-based fallbacks only
DEMO_MODE=false

# MySQL + Prisma
DATABASE_URL="mysql://root:password@localhost:3306/neuroadapt_ai"

PORT=4000
NODE_ENV=development
